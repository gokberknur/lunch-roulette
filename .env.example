# MapTiler key — recommended for production.
# Sign up at https://www.maptiler.com/cloud/ (free tier: 100k tile loads/mo).
# Without a key, MapLibre falls back to raw OSM raster tiles — fine for dev, NOT for production.
PUBLIC_MAPTILER_KEY=

# OpenRouteService API key — required for walking directions.
# Sign up at https://openrouteservice.org/dev/#/signup (free tier: 2000 directions reqs/day).
PUBLIC_ORS_KEY=
